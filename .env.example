# BUJA 환경변수 설정
# 이 파일을 복사해서 .env 파일을 만드세요: cp .env.example .env

# === 데이터베이스 ===
DATABASE_URL=postgresql://buja_user:password@localhost:5432/buja_db
POSTGRES_USER=buja_user
POSTGRES_PASSWORD=password
POSTGRES_DB=buja_db

# === AI / Claude API ===
ANTHROPIC_API_KEY=sk-ant-...

# === NH나무 OpenAPI (조회 전용) ===
# 신청: https://open.nhqv.com
NH_APP_KEY=your_app_key_here
NH_APP_SECRET=your_app_secret_here
NH_ACCOUNT_NO=your_account_number  # 계좌번호
NH_BASE_URL=https://api.nhqv.com  # 실전
# NH_BASE_URL=https://apisandbox.nhqv.com  # 모의투자

# === 유튜브 RSS (API 키 불필요) ===
YOUTUBE_CHANNEL_ID=UCJo6G1u0e_-wS-JQn3T-zEw  # 머니머니코믹스 (머니코믹스 Money Comics)

# === 앱 설정 ===
APP_ENV=development
SECRET_KEY=your-secret-key-here
DEBUG=true

# 주가: yfinance (키 불필요)
# 뉴스: 네이버 금융 RSS / 구글 뉴스 RSS (키 불필요)
# 유튜브: YouTube RSS 피드 (키 불필요)
# 거시경제: 웹 스크래핑 (키 불필요)
